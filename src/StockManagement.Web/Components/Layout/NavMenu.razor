@rendermode InteractiveServer
<MudNavMenu>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
    <MudNavLink Href="/store" Icon="@Icons.Material.Filled.Store">Store</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">MANAGEMENT</MudText>

    <MudNavLink Href="/products" Icon="@Icons.Material.Filled.Inventory2">Products</MudNavLink>
    <MudNavLink Href="/categories" Icon="@Icons.Material.Filled.Category">Categories</MudNavLink>
    <MudNavLink Href="/suppliers" Icon="@Icons.Material.Filled.LocalShipping">Suppliers</MudNavLink>
    <MudNavLink Href="/inventory" Icon="@Icons.Material.Filled.Warehouse">Inventory</MudNavLink>
    <MudNavLink Href="/orders" Icon="@Icons.Material.Filled.ShoppingCart">Orders</MudNavLink>
    <MudNavLink Href="/customers" Icon="@Icons.Material.Filled.People">Customers</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">MANUFACTURING</MudText>

    <MudNavLink Href="/manufacturing" Icon="@Icons.Material.Filled.Factory">Manufacturing</MudNavLink>
    <MudNavLink Href="/bom" Icon="@Icons.Material.Filled.ListAlt">Bill of Materials</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">FINANCE</MudText>

    <MudNavLink Href="/reports" Icon="@Icons.Material.Filled.Assessment">Reports</MudNavLink>

    <MudDivider Class="my-2" />
    <MudText Typo="Typo.caption" Class="px-4 mud-text-secondary">SETTINGS</MudText>

    <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
    <MudNavLink Href="" Icon="@Icons.Material.Filled.Logout" OnClick="HandleLogout">Logout</MudNavLink>
</MudNavMenu>

@code {
    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("submitLogoutForm");
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}
