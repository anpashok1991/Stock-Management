@inherits LayoutComponentBase
@rendermode InteractiveServer
@using StockManagement.Web.Services
@inject ThemeService ThemeService
@inject TenantInitializer TenantInitializer

<MudThemeProvider IsDarkMode="ThemeService.IsDarkMode" Theme="ThemeService.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudSpacer />
        <MudText Typo="Typo.h6">Stock Management ERP</MudText>
        <MudSpacer />
        <MudIconButton Icon="@(ThemeService.IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit" OnClick="ToggleTheme" />
        <MudIconButton Icon="@Icons.Material.Filled.Notifications" Color="Color.Inherit" />
        <MudAvatar Color="Color.Primary">A</MudAvatar>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2" Width="260px">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6" Class="px-4">StockMgmt</MudText>
            <MudText Typo="Typo.body2" Class="px-4 mud-text-secondary">Admin Portal</MudText>
        </MudDrawerHeader>
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @if (!_initialized)
        {
            <div class="d-flex align-center justify-center" style="min-height:60vh;">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else
        {
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="ex">
                    <MudPaper Class="pa-4" Elevation="4">
                        <MudText Typo="Typo.h6">An error occurred</MudText>
                        <MudText Typo="Typo.body2">@ex.Message</MudText>
                        <pre style="white-space:pre-wrap;">@ex.StackTrace</pre>
                    </MudPaper>
                </ErrorContent>
            </ErrorBoundary>
        }
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
    private void ToggleTheme() => ThemeService.ToggleTheme();

    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await TenantInitializer.InitializeAsync();
        }
        catch
        {
            // ignore
        }
        _initialized = true;
    }
}
