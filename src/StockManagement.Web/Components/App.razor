@using Microsoft.AspNetCore.Components.Authorization
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700,900&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="StockManagement.Web.styles.css" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="manifest" href="manifest.json" />
    <meta name="theme-color" content="#594AE2" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>
<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="InteractiveServer" />
    </CascadingAuthenticationState>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
    <script>
        window.submitLoginForm = function (email, password, rememberMe, returnUrl) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Account/Login';
            form.style.display = 'none';

            const e = document.createElement('input');
            e.name = 'Email';
            e.value = email || '';
            form.appendChild(e);

            const p = document.createElement('input');
            p.name = 'Password';
            p.value = password || '';
            form.appendChild(p);

            if (typeof rememberMe !== 'undefined') {
                const r = document.createElement('input');
                r.name = 'RememberMe';
                r.value = rememberMe ? 'true' : 'false';
                form.appendChild(r);
            }

            if (returnUrl) {
                const u = document.createElement('input');
                u.name = 'ReturnUrl';
                u.value = returnUrl;
                form.appendChild(u);
            }

            document.body.appendChild(form);
            form.submit();
        };

        window.submitLogoutForm = function () {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Account/Logout';
            form.style.display = 'none';

            document.body.appendChild(form);
            form.submit();
        };

        window.submitRegisterForm = function (email, password, firstName, lastName) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Account/Register';
            form.style.display = 'none';

            const e = document.createElement('input');
            e.name = 'Email';
            e.value = email || '';
            form.appendChild(e);

            const p = document.createElement('input');
            p.name = 'Password';
            p.value = password || '';
            form.appendChild(p);

            const f = document.createElement('input');
            f.name = 'FirstName';
            f.value = firstName || '';
            form.appendChild(f);

            const l = document.createElement('input');
            l.name = 'LastName';
            l.value = lastName || '';
            form.appendChild(l);

            document.body.appendChild(form);
            form.submit();
        };
    </script>
</body>
</html>
