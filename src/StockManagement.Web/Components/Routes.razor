@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
<Router AppAssembly="typeof(Program).Assembly" @rendermode="InteractiveServer">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <AuthorizeView>
                    <NotAuthorized Context="innerNotAuth">
                        <MudContainer Class="d-flex align-center justify-center" Style="min-height: 80vh;">
                            <MudPaper Class="pa-8" Elevation="3">
                                <MudText Typo="Typo.h5" Class="mb-4">Please sign in to continue</MudText>
                                <MudText Typo="Typo.body1" Class="mb-4">You need to be logged in to access this page.</MudText>
                                <MudButton Href="/login" Variant="Variant.Filled" Color="Color.Primary">Go to Login</MudButton>
                            </MudPaper>
                        </MudContainer>
                    </NotAuthorized>
                    <Authorized Context="innerAuth">
                        <MudContainer Class="d-flex align-center justify-center" Style="min-height: 80vh;">
                            <MudPaper Class="pa-8" Elevation="3">
                                <MudText Typo="Typo.h5" Class="mb-4">Access Denied</MudText>
                                <MudText Typo="Typo.body1" Class="mb-4">You do not have permission to access this page.</MudText>
                                <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary">Go to Dashboard</MudButton>
                            </MudPaper>
                        </MudContainer>
                    </Authorized>
                </AuthorizeView>
            </NotAuthorized>
            <Authorizing>
                <MudContainer Class="d-flex align-center justify-center" Style="min-height: 80vh;">
                    <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                </MudContainer>
            </Authorizing>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>
