@page "/login"
@attribute [AllowAnonymous]
@layout StockManagement.Web.Components.Layout.LoginLayout
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Login - Stock Management ERP</PageTitle>

<MudContainer Class="login-container">
    <MudPaper Class="login-paper pa-8" Elevation="24">
        <div class="login-header">
            <MudIcon Icon="@Icons.Material.Filled.Inventory" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
            <MudText Typo="Typo.h4" Class="mb-1">Stock Management ERP</MudText>
            <MudText Typo="Typo.body1" Class="mb-1 mud-text-secondary">Sign in to your account</MudText>
        </div>

        <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" Required="true"
                      Class="mt-6" />
        <MudTextField @bind-Value="_password" Label="Password" InputType="InputType.Password" Variant="Variant.Outlined" Margin="Margin.Dense"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" Required="true"
                      Class="mt-4" />

        @if (!string.IsNullOrEmpty(_error))
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@_error</MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-6 py-2"
                   OnClick="HandleLogin" Disabled="_loading">
            @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" /> } else { @("Sign In") }
        </MudButton>

        <MudDivider Class="my-6" />
        <MudText Typo="Typo.body2" Align="Align.Center" Class="mud-text-secondary">
            Demo: admin@stockmgmt.com / Admin@123
        </MudText>
    </MudPaper>
</MudContainer>

@code {
    private string _email = "admin@stockmgmt.com";
    private string _password = "Admin@123";
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        try
        {
            await JS.InvokeVoidAsync("submitLoginForm", _email, _password, true, "/");
        }
        catch (Exception ex)
        {
            _error = $"Login failed: {ex.Message}";
            _loading = false;
        }
    }
}
